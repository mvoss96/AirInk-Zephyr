{
    // Better Comments (aaron-bond.better-comments) re-colors every line in a
    // block comment that starts with `*` using its green `*` tag, which makes
    // the `/*` opening line (gray) and the ` * ` continuation lines (green)
    // render in two colors. Disabling multiline processing keeps block comments
    // uniform while leaving the `//` tag highlighting (!, ?, TODO) intact.
    "better-comments.multilineComments": false,

    // Inlay hints (ms-vscode.cpptools): show parameter names at call sites,
    // deduced auto/decl types, and & for reference params. Off by default.
    "editor.inlayHints.enabled": "on",
    "C_Cpp.inlayHints.parameterNames.enabled": true,
    "C_Cpp.inlayHints.parameterNames.hideLeadingUnderscores": true,
    "C_Cpp.inlayHints.referenceOperator.enabled": true,
    "C_Cpp.inlayHints.autoDeclarationTypes.enabled": true,

    // Render the hints smaller and with a little breathing room, so they read as
    // annotations rather than as code.
    "editor.inlayHints.fontSize": 11,
    "editor.inlayHints.padding": true,
    "nrf-connect.applications": [
        "${workspaceFolder}\\apps\\standalone",
        "${workspaceFolder}\\apps\\matter"
    ]
}
