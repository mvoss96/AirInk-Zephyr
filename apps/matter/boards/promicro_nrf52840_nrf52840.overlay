/*
 * The Matter build's devicetree: AirInk's hardware -- the same SCD41, button, e-paper, battery
 * divider and uart0 console as the standalone firmware, and the same flash map.
 *
 * All of it comes from the shared .dtsi. This file used to carry the partition map as the one thing
 * that differed between the builds. It no longer differs: both run on the same board on top of the
 * same bootloader, so the map moved to dts/airink_flash.dtsi (pulled in by airink_hw.dtsi), where
 * both builds get it and where a build cannot forget to ask for it. See that file for the layout,
 * and for why the board's stock map would eat the bootloader.
 */

#include "../../../dts/airink_hw.dtsi"
